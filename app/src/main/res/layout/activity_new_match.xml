<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B16">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/tbNew"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#0B1230"
        app:title="Match Settings"
        app:titleTextColor="#EAF2FF"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:fitsSystemWindows="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tbNew"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#1A2448"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0B1230"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- TEAMS -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teams"
                        android:textColor="#8BFF63"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTeamA"
                        style="@style/WL_NeonInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTeamA"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Team A name" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTeamB"
                        style="@style/WL_NeonInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTeamB"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Team B name" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="#1A2448" />

                    <!-- MATCH -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Match"
                        android:textColor="#00E5FF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/WL_NeonInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etOvers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Overs (e.g. 20)"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/WL_NeonInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPlayers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Players (e.g. 11)"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="#1A2448" />

                    <!-- TOSS -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toss"
                        android:textColor="#8BFF63"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgTossMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbTossNow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toss now"
                            android:textColor="#EAF2FF" />

                        <RadioButton
                            android:id="@+id/rbAlreadyTossed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:text="Already tossed"
                            android:textColor="#EAF2FF" />
                    </RadioGroup>

                    <!-- Toss now -->
                    <LinearLayout
                        android:id="@+id/boxTossNow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvTossStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="Not tossed yet"
                            android:textColor="#A9B6D3"
                            android:textSize="13sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVirtualToss"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:backgroundTint="#00E5FF"
                            android:text="VIRTUAL TOSS"
                            android:textAllCaps="false"
                            android:textColor="#070B16"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                    <!-- Already tossed -->
                    <LinearLayout
                        android:id="@+id/boxAlreadyTossed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toss won by?"
                            android:textColor="#A9B6D3"
                            android:textSize="13sp" />

                        <RadioGroup
                            android:id="@+id/rgTossWinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rbWinnerA"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Team A"
                                android:textColor="#EAF2FF" />

                            <RadioButton
                                android:id="@+id/rbWinnerB"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:text="Team B"
                                android:textColor="#EAF2FF" />
                        </RadioGroup>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Opted to?"
                            android:textColor="#A9B6D3"
                            android:textSize="13sp" />

                        <RadioGroup
                            android:id="@+id/rgOpted"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rbOptBat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bat"
                                android:textColor="#EAF2FF" />

                            <RadioButton
                                android:id="@+id/rbOptBowl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:text="Bowl"
                                android:textColor="#EAF2FF" />
                        </RadioGroup>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom bar: Next always anchored (so user never “misses” it) -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#070B16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="NEXT: PLAYERS"
            android:textAllCaps="false"
            android:textColor="#070B16"
            android:backgroundTint="#8BFF63"
            app:cornerRadius="18dp"
            android:visibility="gone"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
