<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B16">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#0B1230"
        app:titleTextColor="#EAF2FF"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Team"
        android:textColor="#EAF2FF"
        android:textStyle="bold"
        android:textSize="18sp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvLastMatchLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Last match squad"
        android:textColor="#00E5FF"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLastMatch"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvLastMatchLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvEmptyLast"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No squad saved for last match."
        android:textColor="#A9B6D3"
        android:textSize="13sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvLastMatch"
        app:layout_constraintBottom_toBottomOf="@id/rvLastMatch"
        app:layout_constraintStart_toStartOf="@id/rvLastMatch"
        app:layout_constraintEnd_toEndOf="@id/rvLastMatch"/>

    <TextView
        android:id="@+id/tvAllLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="All-time squad"
        android:textColor="#8BFF63"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/rvLastMatch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAllTime"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvAllLabel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvEmptyAll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No players found."
        android:textColor="#A9B6D3"
        android:textSize="13sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvAllTime"
        app:layout_constraintBottom_toBottomOf="@id/rvAllTime"
        app:layout_constraintStart_toStartOf="@id/rvAllTime"
        app:layout_constraintEnd_toEndOf="@id/rvAllTime"/>
</androidx.constraintlayout.widget.ConstraintLayout>
