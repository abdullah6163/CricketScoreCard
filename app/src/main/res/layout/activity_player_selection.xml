<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B16">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/tbSelect"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#0B1230"
        app:title="Select Opening"
        app:titleTextColor="#EAF2FF"
        android:titleTextColor="#EAF2FF"
        android:subtitleTextColor="#A9B6D3"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="14dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#1A2448"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tbSelect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0B1230"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMatch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team A vs Team B"
                android:textStyle="bold"
                android:textColor="#EAF2FF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvBatBowl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Batting: Team A  |  Bowling: Team B"
                android:textColor="#A9B6D3"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPick"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#1A2448"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/cardInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0B1230"
            android:padding="16dp"
            android:orientation="vertical"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPENING BATSMEN"
                android:textStyle="bold"
                android:textColor="#7CFF6B"/>

            <!-- Striker -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStriker"
                style="@style/WL_DropdownInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Striker"
                app:startIconDrawable="@drawable/ic_bat">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/acStriker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="true"
                    android:textColor="#EAF2FF"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Non-striker -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNonStriker"
                style="@style/WL_DropdownInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Non-striker"
                app:startIconDrawable="@drawable/ic_bat">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/acNonStriker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="true"
                    android:textColor="#EAF2FF"/>
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A2448"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPENING BOWLER"
                android:textStyle="bold"
                android:textColor="#00E5FF"/>

            <!-- Bowler -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilBowler"
                style="@style/WL_DropdownInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Bowler"
                app:startIconDrawable="@drawable/ic_ball">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/acBowler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="true"
                    android:textColor="#EAF2FF"/>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartScoring"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_margin="14dp"
        android:text="START SCORING"
        android:textColor="#070B16"
        android:backgroundTint="#7CFF6B"
        app:cornerRadius="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
