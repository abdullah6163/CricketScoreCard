<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1E2A52"
    app:cardBackgroundColor="#0B1230">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOverNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Over 1"
                android:textStyle="bold"
                android:textColor="#EAF2FF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvOverRuns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="0 Runs"
                android:textColor="#25F4FF"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvOverBowler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bowler: Fahim"
            android:textColor="#9FB2FF"
            android:textSize="13sp"
            android:layout_marginTop="6dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBalls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:overScrollMode="never"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
