<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B16">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#0B1230"
        app:title="Players"
        app:titleTextColor="#EAF2FF"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="14dp"
        app:boxBackgroundMode="filled"
        app:boxBackgroundColor="#0B1230"
        app:boxCornerRadiusTopStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusBottomEnd="16dp"
        app:hintTextColor="#A9B6D3"

        app:startIconDrawable="@drawable/ic_search_24"
        app:startIconTint="#A9B6D3"

        app:endIconMode="clear_text"
        app:endIconTint="#A9B6D3"

        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search players"
            android:textColor="#EAF2FF"
            android:textColorHint="#A9B6D3"
            android:singleLine="true"/>
    </com.google.android.material.textfield.TextInputLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlayers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="6dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tilSearch"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/tvLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading players..."
        android:textColor="#A9B6D3"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvPlayers"
        app:layout_constraintBottom_toBottomOf="@id/rvPlayers"
        app:layout_constraintStart_toStartOf="@id/rvPlayers"
        app:layout_constraintEnd_toEndOf="@id/rvPlayers"/>


    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No players yet"
        android:textColor="#A9B6D3"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvPlayers"
        app:layout_constraintBottom_toBottomOf="@id/rvPlayers"
        app:layout_constraintStart_toStartOf="@id/rvPlayers"
        app:layout_constraintEnd_toEndOf="@id/rvPlayers"/>

</androidx.constraintlayout.widget.ConstraintLayout>
