<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B16">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/tbScore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#0B1230"
        android:titleTextColor="#EAF2FF"
        android:subtitleTextColor="#A9B6D3"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- TOP SCORE CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="22dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A2448"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tbScore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0B1230"
            android:padding="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvInnings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team A innings"
                android:textColor="#A9B6D3"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvScoreLine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 - 0 (0.0)"
                    android:textColor="#EAF2FF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOverProgressLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0/10"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#8BFF63"
                    android:paddingStart="8dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvCRR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CRR 0.00"
                android:textColor="#00E5FF"
                android:layout_marginTop="4dp"/>

            <!-- 2nd innings chase info -->
            <TextView
                android:id="@+id/tvChaseLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target: -   Need: -   Balls: -"
                android:textColor="#A9B6D3"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvRRR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RRR 0.00"
                android:textColor="#FFD54F"
                android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- MID CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="2dp"
        app:cardCornerRadius="22dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A2448"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardTop"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- keep it scrollable only for safety, but page will fit -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0B1230"
                android:padding="16dp"
                android:orientation="vertical">

                <!-- BATSMEN -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATSMEN"
                    android:textStyle="bold"
                    android:textColor="#8BFF63"/>

                <!-- header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text="Batsman"
                        android:textColor="#A9B6D3"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="R" android:gravity="center" android:textColor="#A9B6D3"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="B" android:gravity="center" android:textColor="#A9B6D3"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="4s" android:gravity="center" android:textColor="#A9B6D3"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="6s" android:gravity="center" android:textColor="#A9B6D3"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2"
                        android:text="SR" android:gravity="center" android:textColor="#A9B6D3"/>
                </LinearLayout>

                <!-- striker row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvBatAName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:textColor="#EAF2FF"
                        android:textStyle="bold"/>

                    <TextView android:id="@+id/tvBatAR" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatAB" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatA4" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatA6" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatASR" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:gravity="center" android:textColor="#EAF2FF"/>
                </LinearLayout>

                <!-- non striker row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvBatBName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:textColor="#EAF2FF"

                        />

                    <TextView android:id="@+id/tvBatBR" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatBB" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatB4" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatB6" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBatBSR" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:gravity="center" android:textColor="#EAF2FF"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A2448"
                    android:layout_marginVertical="14dp"/>

                <!-- BOWLER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BOWLER"
                    android:textStyle="bold"
                    android:textColor="#00E5FF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text="Bowler"
                        android:textColor="#A9B6D3"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2"
                        android:text="O" android:gravity="center" android:textColor="#A9B6D3"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="R" android:gravity="center" android:textColor="#A9B6D3"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="W" android:gravity="center" android:textColor="#A9B6D3"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2"
                        android:text="Econ" android:gravity="center" android:textColor="#A9B6D3"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvBowlerName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:textColor="#EAF2FF"
                        android:textStyle="bold"/>

                    <TextView android:id="@+id/tvBowlerO" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1.2" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBowlerR" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBowlerW" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:textColor="#EAF2FF"/>
                    <TextView android:id="@+id/tvBowlerEcon" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:gravity="center" android:textColor="#EAF2FF"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A2448"
                    android:layout_marginVertical="14dp"/>

                <!-- THIS OVER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="THIS OVER"
                        android:textStyle="bold"
                        android:textColor="#A9B6D3"/>

                    <TextView
                        android:id="@+id/tvThisOverTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Over Total: 0"
                        android:textStyle="bold"
                        android:textColor="#8BFF63"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:scrollbars="none">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvThisOver"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:overScrollMode="never"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"/>

                </HorizontalScrollView>

                <!-- Extras row (NO legbye) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbWide"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Wide"
                        android:textColor="#EAF2FF"/>

                    <CheckBox
                        android:id="@+id/cbNoBall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="No Ball"
                        android:textColor="#EAF2FF"/>

                    <CheckBox
                        android:id="@+id/cbByes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Byes"
                        android:textColor="#EAF2FF"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- BOTTOM -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUndo"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="Undo"
                android:textColor="#EAF2FF"
                android:backgroundTint="#0F1838"
                app:cornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1A2448"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSwap"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Swap"
                android:textColor="#EAF2FF"
                android:backgroundTint="#0F1838"
                app:cornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1A2448"/>
        </LinearLayout>

        <!-- Buttons spacing like your previous sample:
             add margins per item to create gaps -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="4"
            android:rowCount="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:text="0"
                android:backgroundTint="#8BFF63"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:text="1"
                android:backgroundTint="#8BFF63"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:text="2"
                android:backgroundTint="#8BFF63"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="10dp"
                android:text="3"
                android:backgroundTint="#00E5FF"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="10dp"
                android:text="4"
                android:backgroundTint="#00E5FF"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="10dp"
                android:text="5"
                android:backgroundTint="#00E5FF"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="10dp"
                android:text="6"
                android:backgroundTint="#00E5FF"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnW"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="W"
                android:backgroundTint="#FF3B30"
                android:textColor="#070B16"
                app:cornerRadius="16dp"/>
        </GridLayout>

    </LinearLayout>


    <View
        android:id="@+id/vCelebrationDim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#B3000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCelebration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="18dp"
        android:text="TEAM WON!"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="28sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <View
        android:id="@+id/viewDim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="#99000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- GIF EFFECT (on top of dim) -->
    <ImageView
        android:id="@+id/ivEffectGif"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:visibility="gone"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <nl.dionsegijn.konfetti.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
