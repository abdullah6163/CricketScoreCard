        <item name="cornerSize">50%</item>
    </style>



    <style name="ToolbarTitleSmall" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">10sp</item>
    </style>
    <style name="ToolbarSubtitleSmall" parent="TextAppearance.Widget.AppCompat.Toolbar.Subtitle">
        <item name="android:textSize">14sp</item>
    </style>


    <!-- ✅ Your existing style (keep) -->
    <style name="WL_CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

