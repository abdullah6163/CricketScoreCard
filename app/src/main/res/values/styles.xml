<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ✅ Your existing style (keep) -->
    <style name="WL_DropdownInput" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">#0F1A3A</item>
        <item name="boxStrokeColor">#2A3B70</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>

        <item name="hintTextColor">#B8C0D0</item>
        <item name="android:textColor">#EAF2FF</item>

        <item name="endIconMode">dropdown_menu</item>
        <item name="endIconTint">#7CFF6B</item>
        <item name="startIconTint">#00E5FF</item>
